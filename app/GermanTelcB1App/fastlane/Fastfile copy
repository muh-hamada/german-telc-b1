# Helper method to wait for build to be available in App Store Connect
def wait_for_build_processing(bundle_id, build_number, max_wait_minutes: 10)
  UI.message("⏳ Waiting for build #{build_number} to be processed by TestFlight...")
  
  max_attempts = max_wait_minutes * 4  # Check every 15 seconds
  attempt = 0
  
  while attempt < max_attempts
    begin
      # Login to App Store Connect first
      Spaceship::ConnectAPI.login
      
      # Get the app
      app = Spaceship::ConnectAPI::App.find(bundle_id)
      
      unless app
        UI.error("Could not find app with bundle ID: #{bundle_id}")
        sleep(15)
        attempt += 1
        next
      end
      
      # Get all builds for this app
      builds = app.get_builds(
        filter: { version: build_number.to_s },
        includes: "preReleaseVersion",
        limit: 1
      )
      
      build = builds.first
      
      if build
        # Check if build is processed
        if build.processing_state == "VALID" || build.processing_state == "PROCESSING_COMPLETE"
          UI.success("✅ Build #{build_number} is ready! (State: #{build.processing_state})")
          return true
        else
          UI.message("   Build found but still processing... State: #{build.processing_state} (attempt #{attempt + 1}/#{max_attempts})")
        end
      else
        UI.message("   Build #{build_number} not found yet... (attempt #{attempt + 1}/#{max_attempts})")
      end
      
      sleep(15)  # Wait 15 seconds before checking again
      attempt += 1
      
    rescue => e
      UI.message("   Error checking build: #{e.message} (attempt #{attempt + 1}/#{max_attempts})")
      sleep(15)
      attempt += 1
    end
  end
  
  UI.error("⚠️  Build #{build_number} was not processed within #{max_wait_minutes} minutes")
  UI.error("   This could mean:")
  UI.error("   1. The build is taking longer than usual to process")
  UI.error("   2. There was an issue with the build upload")
  UI.error("   Please check TestFlight in App Store Connect manually")
  return false
end

platform :android do
  desc "Upload AAB to Google Play Store and create release"
  lane :release do |options|
    # Validate required parameters
    unless options[:app_id]
      UI.user_error!("app_id parameter is required")
    end
    
    unless options[:aab_path]
      UI.user_error!("aab_path parameter is required")
    end
    
    unless options[:message_index]
      UI.user_error!("message_index parameter is required")
    end
    
    app_config = get_app_config(options[:app_id])
    package_name = app_config[:android_package]
    aab_path = options[:aab_path]
    message_index = options[:message_index].to_i
    rollout = options[:rollout] || 1.0  # Default to 100% rollout
    track = options[:track] || "production"
    
    # Validate AAB file exists
    unless File.exist?(aab_path)
      UI.user_error!("AAB file not found at: #{aab_path}")
    end
    
    # Load update message
    update_message = load_update_message(message_index)
    
    UI.message("📦 Uploading to Play Store...")
    UI.message("   App: #{options[:app_id]}")
    UI.message("   Package: #{package_name}")
    UI.message("   AAB: #{aab_path}")
    UI.message("   Track: #{track}")
    UI.message("   Rollout: #{(rollout * 100).to_i}%")
    
    # Write changelogs to metadata directory
    metadata_path = write_play_store_changelogs(package_name, update_message)
    
    # Upload to Google Play
    upload_to_play_store(
      package_name: package_name,
      aab: aab_path,
      track: track,
      rollout: rollout,  # Already a float, no need to convert to string
      release_status: "completed",
      metadata_path: metadata_path,
      skip_upload_metadata: true,
      skip_upload_images: true,
      skip_upload_screenshots: true,
      skip_upload_changelogs: false
    )
    
    UI.success("✅ Successfully uploaded #{options[:app_id]} to Google Play Store!")
  end
end

platform :ios do
  desc "Create release in App Store Connect and submit for review"
  lane :release do |options|
    # Validate required parameters
    unless options[:app_id]
      UI.user_error!("app_id parameter is required")
    end
    
    unless options[:version]
      UI.user_error!("version parameter is required")
    end
    
    unless options[:build_number]
      UI.user_error!("build_number parameter is required")
    end
    
    unless options[:message_index]
      UI.user_error!("message_index parameter is required")
    end
    
    app_config = get_app_config(options[:app_id])
    bundle_id = app_config[:ios_bundle_id]
    version = options[:version]
    build_number = options[:build_number]
    message_index = options[:message_index].to_i
    
    # Load update message (has keys like "en", "de", "es", "fr", "ar", "tr", "ja", "ko", etc.)
    update_message = load_update_message(message_index)
    
    # Load App Store metadata with placeholders replaced
    # app_metadata[:description] has keys like "en-US", "de-DE", "es-ES", etc. (9 locales from our JSON)
    # app_metadata[:keywords] same structure
    # app_metadata[:support_url] and [:marketing_url] are plain strings
    app_metadata = load_app_store_metadata(options[:app_id])
    
    UI.message("   🔍 Detecting configured localizations for #{bundle_id}...")
    
    # Login to App Store Connect
    Spaceship::ConnectAPI.login
    app = Spaceship::ConnectAPI::App.find(bundle_id)
    
    unless app
      UI.user_error!("Could not find app with bundle ID: #{bundle_id}")
    end
    
    # ──────────────────────────────────────────────────────────────────────
    # STEP 1: Detect configured locales from App Store Connect
    #
    # App Store Connect requires that EVERY configured locale has:
    #   - whatsNew (release notes)
    #   - description
    #   - keywords
    #   - supportUrl
    # If we miss any, the submission is rejected.
    #
    # We try multiple API methods because depending on app state
    # (no edit version yet, pending review, etc.) different APIs work.
    # ──────────────────────────────────────────────────────────────────────
    configured_locales = []
    
    # Method 1: Try to get locales from existing app store versions
    begin
      versions = app.get_app_store_versions(filter: { platform: "IOS" })
      if versions && !versions.empty?
        versions.each do |ver|
          begin
            version_localizations = ver.get_app_store_version_localizations
            if version_localizations && !version_localizations.empty?
              configured_locales = version_localizations.map { |loc| loc.locale }
              UI.message("   ✅ Detected #{configured_locales.length} locales from app store version (state: #{ver.app_store_state})")
              break
            end
          rescue => e
            UI.message("   ⚠️  Could not get localizations from version (#{ver.app_store_state}): #{e.message}")
          end
        end
      end
    rescue => e
      UI.message("   ⚠️  Could not fetch app store versions: #{e.message}")
    end
    
    # Method 2: Fallback to app info localizations
    if configured_locales.empty?
      begin
        app_info = app.fetch_edit_app_info || app.fetch_live_app_info
        if app_info
          app_info_localizations = app_info.get_app_info_localizations
          if app_info_localizations && !app_info_localizations.empty?
            configured_locales = app_info_localizations.map { |loc| loc.locale }
            UI.message("   ✅ Detected #{configured_locales.length} locales from app info")
          end
        end
      rescue => e
        UI.message("   ⚠️  Could not fetch app info localizations: #{e.message}")
      end
    end
    
    # Method 3: Last resort — en-US is always safe
    if configured_locales.empty?
      UI.message("   ⚠️  Could not detect configured locales, defaulting to en-US only")
      configured_locales = ["en-US"]
    end
    
    UI.message("   📍 Configured locales: #{configured_locales.join(', ')}")
    
    # ──────────────────────────────────────────────────────────────────────
    # STEP 2: Build localized data for EVERY configured locale.
    #
    # Mapping: App Store Connect locale code -> update_message short key
    # Some apps use short codes (e.g. "tr", "ar") and some use full
    # codes (e.g. "tr-TR", "ar-SA"). We handle both directions.
    # ──────────────────────────────────────────────────────────────────────
    
    # Maps App Store locale -> short key in update_message / metadata JSON
    reverse_locale_map = {
      "en-US" => "en", "de-DE" => "de", "es-ES" => "es", "fr-FR" => "fr",
      "it-IT" => "it", "pt-PT" => "pt", "pt-BR" => "pt", "ru-RU" => "ru",
      "ar-SA" => "ar", "ar" => "ar", "tr-TR" => "tr", "tr" => "tr"
    }
    
    # Maps short key -> App Store full locale (used for looking up our metadata)
    forward_locale_map = {
      "en" => "en-US", "de" => "de-DE", "es" => "es-ES", "fr" => "fr-FR",
      "it" => "it-IT", "pt" => "pt-PT", "ru" => "ru-RU", "ar" => "ar", "tr" => "tr-TR"
    }
    
    en_release_note = remove_emojis(update_message["en"] || "Bug fixes and improvements")
    en_description = app_metadata[:description]["en-US"] || ""
    en_keywords = app_metadata[:keywords]["en-US"] || ""
    
    ios_release_notes = {}
    ios_descriptions = {}
    ios_keywords = {}
    ios_support_url = {}
    ios_marketing_url = {}
    
    configured_locales.each do |app_store_locale|
      # Find the short key for this locale (e.g. "de-DE" -> "de", "tr" -> "tr")
      short_key = reverse_locale_map[app_store_locale]
      
      # Also try to find the metadata locale key (how load_app_store_metadata indexed it)
      # Our metadata uses forward_locale_map values as keys (e.g. "en-US", "de-DE", "tr-TR")
      # But App Store Connect might report "tr" while our metadata has "tr-TR"
      metadata_locale = app_store_locale
      if short_key && forward_locale_map[short_key]
        metadata_locale = forward_locale_map[short_key]
      end
      
      # Release notes: use translated update_message, or English fallback
      if short_key && update_message[short_key]
        ios_release_notes[app_store_locale] = remove_emojis(update_message[short_key])
      elsif update_message[app_store_locale]
        # Try direct match (e.g. "pt-BR" key exists in update_message)
        ios_release_notes[app_store_locale] = remove_emojis(update_message[app_store_locale])
      else
        ios_release_notes[app_store_locale] = en_release_note
        UI.message("   ⚠️  No release note for '#{app_store_locale}', using English")
      end
      
      # Description: use localized metadata, or English fallback
      ios_descriptions[app_store_locale] = app_metadata[:description][metadata_locale] ||
                                           app_metadata[:description][app_store_locale] ||
                                           en_description
      
      # Keywords: use localized metadata, or English fallback
      ios_keywords[app_store_locale] = app_metadata[:keywords][metadata_locale] ||
                                       app_metadata[:keywords][app_store_locale] ||
                                       en_keywords
      
      # URLs: same for all locales
      ios_support_url[app_store_locale] = app_metadata[:support_url]
      ios_marketing_url[app_store_locale] = app_metadata[:marketing_url]
    end
    
    UI.message("   📝 Release notes for: #{ios_release_notes.keys.join(', ')}")
    UI.message("   📝 Descriptions for: #{ios_descriptions.keys.join(', ')}")
    
    UI.message("🍎 Creating App Store release...")
    UI.message("   App: #{options[:app_id]}")
    UI.message("   Bundle ID: #{bundle_id}")
    UI.message("   Version: #{version}")
    UI.message("   Build: #{build_number}")
    
    # Wait for build to be processed by TestFlight (max 10 minutes)
    unless wait_for_build_processing(bundle_id, build_number, max_wait_minutes: 10)
      UI.user_error!("Build #{build_number} not ready. Please check TestFlight and try again later.")
    end
    
    # Create/update app version in App Store Connect
    deliver(
      app_identifier: bundle_id,
      app_version: version,
      build_number: build_number.to_s,
      skip_binary_upload: true,
      skip_screenshots: true,
      skip_metadata: false,
      force: true,
      submit_for_review: true,
      automatic_release: true,
      
      # All fields provided for EVERY configured locale
      release_notes: ios_release_notes,
      description: ios_descriptions,
      keywords: ios_keywords,
      support_url: ios_support_url,
      marketing_url: ios_marketing_url
    )
    
    UI.success("✅ Successfully created and submitted release for #{options[:app_id]} in App Store Connect!")
  end
end
